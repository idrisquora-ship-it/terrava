# Terrava Environment Example (Flutter)
# Copy to `.env` and fill real values.
# NEVER commit `.env` with production secrets.

# -----------------------------
# App
# -----------------------------
APP_ENV=development
APP_NAME=Terrava

# -----------------------------
# Supabase (Project Settings → API)
# -----------------------------
SUPABASE_URL=https://ghwokfnrimqpvuiuzaly.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_OR_PUBLISHABLE_KEY

# -----------------------------
# Mapbox (maps tiles, geocoding, directions)
# Create a public token (pk.*) — see doc/MAPBOX_FOURSQUARE_SETUP.md
# -----------------------------
MAPBOX_ACCESS_TOKEN=pk.YOUR_MAPBOX_ACCESS_TOKEN
# Alias also accepted: MAPBOX_PUBLIC_TOKEN (same pk.* value)

# -----------------------------
# Foursquare Places (nearby categories + place details)
# -----------------------------
FOURSQUARE_API_KEY=YOUR_FOURSQUARE_API_KEY

# -----------------------------
# Google OAuth Web client ID (Sign-In only — not Maps)
# NEVER put OAuth client secrets in the client.
# -----------------------------
GOOGLE_OAUTH_CLIENT_ID=YOUR_GOOGLE_OAUTH_CLIENT_ID.apps.googleusercontent.com

# -----------------------------
# WeatherAPI / ExchangeRate
# -----------------------------
WEATHER_API_KEY=YOUR_WEATHER_API_KEY
EXCHANGE_RATE_API_KEY=YOUR_EXCHANGE_RATE_API_KEY

# -----------------------------
# Feature flags
# -----------------------------
ENABLE_APPLE_SIGN_IN=false
ENABLE_VOICE_SEARCH=false
ENABLE_AI_SUMMARY=false

# Deep link for password reset (mobile). Must match Supabase Additional Redirect URLs.
AUTH_REDIRECT_URL=com.terrava.terrava://login-callback/

# Optional HTTPS redirect for the website (defaults to current browser origin).
WEB_AUTH_REDIRECT_URL=

# Optional crash reporting (leave empty to disable)
SENTRY_DSN=
